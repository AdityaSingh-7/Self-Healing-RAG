# ============================================
# RAG System — Environment Variables
# ============================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets!
# ============================================

# --- Pinecone (Vector Database) ---
# Get these from: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=rag-system

# --- Groq (LLM Inference) ---
# Get this from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# --- Auth ---
# Must match NEXTAUTH_SECRET in frontend .env.local
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# --- App Settings ---
# Frontend URL (for CORS - which websites can talk to this backend)
FRONTEND_URL=http://localhost:3000

# Embedding model (don't change unless you know what you're doing)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM model on Groq
LLM_MODEL=llama-3.3-70b-versatile

# Retrieval settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
RECENCY_WEIGHT=0.2
RECENCY_HALF_LIFE_DAYS=30
